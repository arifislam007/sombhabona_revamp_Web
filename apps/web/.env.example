# Local development environment variables.
# Copy this file's shape to .env.local for secrets that should not be committed.

DATABASE_URL="postgresql://CHANGE_ME:CHANGE_ME@localhost:5432/sombhabona?schema=public"

# SMTP (used to email staff on form submissions)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
