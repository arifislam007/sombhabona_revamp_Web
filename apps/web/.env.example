# bKash Payment Gateway (Tokenized Checkout API) — sandbox credentials for development
BKASH_BASE_URL="https://tokenized.sandbox.bka.sh/v1.2.0-beta"
BKASH_APP_KEY=""
BKASH_APP_SECRET=""
BKASH_USERNAME=""
BKASH_PASSWORD=""

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
